# App password — required, set before deploying
APP_PASSWORD=change-me-before-deploying

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/threads_analytics

# Token encryption key — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key

# Optional — secures /api/cron/sync in production (e.g. Vercel Cron Jobs)
# CRON_SECRET=

# Optional — enables the built-in polling scheduler; set true only on
# long-running deployments (Docker / VPS / Railway / Zeabur)
# SYNC_SCHEDULER_ENABLED=false
